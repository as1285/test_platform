<?xml version='1.0' encoding='utf-8'?>
<widget id="com.testplatform.app" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0" xmlns:android="http://schemas.android.com/apk/res/android">
    <name>个人所得税</name>
    <description>个人所得税移动端应用</description>
    <author email="dev@localhost" href="https://localhost">Tax Bureau Team</author>
    <content src="index.html" />

    <access origin="*" />
    <!-- 允许 WebView 在 iframe 或跳转中加载远程 http(s)，与壳内白名单一致 -->
    <allow-navigation href="http://*/*" />
    <allow-navigation href="https://*/*" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    <allow-intent href="tel:*" />
    <allow-intent href="sms:*" />
    <allow-intent href="mailto:*" />
    <allow-intent href="geo:*" />
    <preference name="AndroidInsecureFileModeEnabled" value="true" />
    <preference name="loadUrlTimeoutValue" value="120000" />
    <!-- 不显示 Cordova 原生标题栏，避免顶部多出一条类似浏览器标题的区域 -->
    <preference name="ShowTitle" value="false" />
    <!-- 关闭 WebView 远程调试（避免 Debug 包默认开启调试相关行为） -->
    <preference name="InspectableWebview" value="false" />
    <!-- 启动屏：cordova-android 11+ 使用 Android 12+ SplashScreen API（见下方 Android 专用 preference） -->
    <preference name="AutoHideSplashScreen" value="true" />
    <preference name="SplashScreenDelay" value="2500" />
    <preference name="FadeSplashScreen" value="true" />
    <preference name="FadeSplashScreenDuration" value="400" />
    <!-- 允许加载 http:// 站点（非 HTTPS）；若以后改为全站 HTTPS 可去掉此段 -->
    <platform name="android">
        <!-- 桌面图标：同一 PNG 须为每个 density 各写一条，否则只会写入 mdpi，其它密度仍为模板默认「i」图标 -->
        <icon density="ldpi" src="res/icon/icon.png" />
        <icon density="mdpi" src="res/icon/icon.png" />
        <icon density="hdpi" src="res/icon/icon.png" />
        <icon density="xhdpi" src="res/icon/icon.png" />
        <icon density="xxhdpi" src="res/icon/icon.png" />
        <icon density="xxxhdpi" src="res/icon/icon.png" />
        <edit-config file="app/src/main/AndroidManifest.xml" mode="merge" target="/manifest/application">
            <application android:usesCleartextTraffic="true" />
        </edit-config>
        <!-- Android 12+ 系统启动屏：白底 + 中间图标（勿再用已弃用的 <splash> 标签） -->
        <preference name="SplashScreenBackgroundColor" value="#FFFFFF" />
        <preference name="AndroidWindowSplashScreenAnimatedIcon" value="res/icon/icon.png" />
    </platform>
</widget>
